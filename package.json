{
  "name": "@csi-foxbyte/regensburg_digitalerenergiezwilling_energycalculationcore",
  "version": "0.2.0",
  "description": "Domain-based TypeScript energy calculation core with JSON-configurable catalogs and rules for building envelope and heating evaluation.",
  "type": "module",
  "main": "./dist/index.cjs",
  "scripts": {
    "test": "node --test --import tsx \"test/**/*.test.ts\"",
    "build": "pnpm run lint && pnpm run test && tsdown",
    "lint": "tsc --noEmit",
    "docs:api": "typedoc --options typedoc.json",
    "configurator:build": "tsx scripts/generate-configurator.ts",
    "docs": "pnpm run docs:api && pnpm run configurator:build",
    "prepack": "pnpm run build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/csi-FOXBYTE/Regensburg_DigitalerEnergieZwilling_EnergyCalculationCore.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "packageManager": "pnpm@10.7.1",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "esbuild": "^0.27.3",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "ts-json-schema-generator": "^2.9.0",
    "tsdown": "^0.21.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  }
}
